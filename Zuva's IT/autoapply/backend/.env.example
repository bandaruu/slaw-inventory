# ZUVA IT Backend – Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/zuva-it?retryWrites=true&w=majority

# ── Server ────────────────────────────────────────────
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# ── JWT ───────────────────────────────────────────────
# Generate: node -e "require('crypto').randomBytes(64).toString('hex').then(console.log)"
JWT_SECRET=change-me-to-a-random-64-char-string

# ── Encryption ────────────────────────────────────────
ENCRYPTION_KEY=change-me-to-a-32-char-string-123

# ── Google OAuth + Gmail ──────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Razorpay ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# ── Stripe (optional) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...

# ── Adzuna Jobs API (optional – free tier) ────────────
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_API_KEY=your-adzuna-api-key
